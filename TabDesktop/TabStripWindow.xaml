<Window x:Class="TabDesktop.TabStripWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TabDesktop"
        Title="" WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True" ShowActivated="False" AllowsTransparency="True" Background="Transparent">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3D6B8F" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <DockPanel>
        <Popup x:Name="TabActionsPopup" StaysOpen="False" Placement="Top" AllowsTransparency="True">
            <Border Background="#FF1E1E1E" BorderBrush="#FF3A3A3A" BorderThickness="1" CornerRadius="3" Padding="3">
                <StackPanel Orientation="Horizontal">
                    <Button Click="OnToggleFolderTitle" ToolTip="Show the process's directory as the title — applies to every window of this program and is remembered">
                        <Viewbox Width="22" Height="22" Margin="4">
                            <Viewbox.Style>
                                <Style TargetType="Viewbox">
                                    <Setter Property="Opacity" Value="1" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DirectoryTitle}" Value="{x:Null}">
                                            <Setter Property="Opacity" Value="0.35" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Viewbox.Style>
                            <Canvas Width="24" Height="24">
                                <Path Fill="#C98A2B" Data="M2,20.6 L2,4.8 Q2,3.4 3.4,3.4 L8.7,3.4 Q9.7,3.4 10.3,4.2 L11.9,6.2 L20.6,6.2 Q22,6.2 22,7.6 L22,20.6 Q22,22 20.6,22 L3.4,22 Q2,22 2,20.6 Z" />
                                <Path Data="M2,20.6 L2,9.4 Q2,8 3.4,8 L20.6,8 Q22,8 22,9.4 L22,20.6 Q22,22 20.6,22 L3.4,22 Q2,22 2,20.6 Z">
                                    <Path.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#FFD978" Offset="0" />
                                            <GradientStop Color="#F2AE3D" Offset="1" />
                                        </LinearGradientBrush>
                                    </Path.Fill>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Click="OnToggleVideoThumbnail" ToolTip="Show video thumbnails for this tab's site — whitelists the domain and is remembered">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBrowserTab}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Viewbox Width="22" Height="22" Margin="4">
                            <Viewbox.Style>
                                <Style TargetType="Viewbox">
                                    <Setter Property="Opacity" Value="0.35" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVideoThumbnailEnabled}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Viewbox.Style>
                            <Canvas Width="24" Height="24">
                                <Path Data="M2,9.5 L22,9.5 L22,19.6 Q22,21 20.6,21 L3.4,21 Q2,21 2,19.6 Z">
                                    <Path.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4A505B" Offset="0" />
                                            <GradientStop Color="#262932" Offset="1" />
                                        </LinearGradientBrush>
                                    </Path.Fill>
                                </Path>
                                <Path Fill="#262932" Data="M2,4.4 Q2,3 3.4,3 L20.6,3 Q22,3 22,4.4 L22,8.6 L2,8.6 Z" />
                                <Path Fill="#ECEFF4" Clip="M2,4.4 Q2,3 3.4,3 L20.6,3 Q22,3 22,4.4 L22,8.6 L2,8.6 Z" Data="M3,3 L6.4,3 L4.4,8.6 L1,8.6 Z M9,3 L12.4,3 L10.4,8.6 L7,8.6 Z M15,3 L18.4,3 L16.4,8.6 L13,8.6 Z M21,3 L24.4,3 L22.4,8.6 L19,8.6 Z" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Click="OnToggleScreenshotThumbnail" ToolTip="Use a screenshot (captured while the window is focused) as the thumbnail — whitelists this site's domain on browser tabs, otherwise every window of this program; remembered">
                        <Viewbox Width="22" Height="22" Margin="4">
                            <Viewbox.Style>
                                <Style TargetType="Viewbox">
                                    <Setter Property="Opacity" Value="0.35" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScreenshotThumbnailEnabled}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Viewbox.Style>
                            <Canvas Width="24" Height="24">
                                <Path Fill="#3B414C" Data="M8.6,6.6 L9.6,4.3 Q9.9,3.6 10.7,3.6 L13.3,3.6 Q14.1,3.6 14.4,4.3 L15.4,6.6 Z" />
                                <Path Data="M2,7.8 Q2,6.4 3.4,6.4 L20.6,6.4 Q22,6.4 22,7.8 L22,19 Q22,20.4 20.6,20.4 L3.4,20.4 Q2,20.4 2,19 Z">
                                    <Path.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#5C6470" Offset="0" />
                                            <GradientStop Color="#30353F" Offset="1" />
                                        </LinearGradientBrush>
                                    </Path.Fill>
                                </Path>
                                <Rectangle Canvas.Left="3.8" Canvas.Top="8.4" Width="3.2" Height="1.9" RadiusX="0.7" RadiusY="0.7" Fill="#F5D06A" />
                                <Ellipse Canvas.Left="6.8" Canvas.Top="8.2" Width="10.4" Height="10.4">
                                    <Ellipse.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#D3D8E0" Offset="0" />
                                            <GradientStop Color="#878E9A" Offset="1" />
                                        </LinearGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Ellipse Canvas.Left="8.3" Canvas.Top="9.7" Width="7.4" Height="7.4">
                                    <Ellipse.Fill>
                                        <RadialGradientBrush GradientOrigin="0.35,0.3">
                                            <GradientStop Color="#6E9BEC" Offset="0" />
                                            <GradientStop Color="#233866" Offset="0.75" />
                                            <GradientStop Color="#131C31" Offset="1" />
                                        </RadialGradientBrush>
                                    </Ellipse.Fill>
                                </Ellipse>
                                <Ellipse Canvas.Left="9.7" Canvas.Top="10.7" Width="2.2" Height="1.6" Fill="#B0FFFFFF" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                    <Button Click="OnToggleExpandTabs" ToolTip="Expand this browser window into one entry per browser tab — click an entry to switch to that tab (needs the extension)">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CanExpandTabs}" Value="False">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <Viewbox Width="22" Height="22" Margin="4">
                            <Viewbox.Style>
                                <Style TargetType="Viewbox">
                                    <Setter Property="Opacity" Value="0.35" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ExpandTabs}" Value="True">
                                            <Setter Property="Opacity" Value="1" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Viewbox.Style>
                            <Canvas Width="24" Height="24">
                                <Path Fill="#EAD9B8" Data="M3.6,14 L3.6,5 Q3.6,3.8 4.8,3.8 L8.4,3.8 Q9.6,3.8 9.6,5 L9.6,6.8 L19.2,6.8 Q20.4,6.8 20.4,8 L20.4,14 Z" />
                                <Path Fill="#F8EEDA" Data="M4.6,14 L4.6,10 Q4.6,8.8 5.8,8.8 L13.8,8.8 L13.8,7.4 Q13.8,6.2 15,6.2 L18.6,6.2 Q19.8,6.2 19.8,7.4 L19.8,14 Z" />
                                <Path Data="M2,19.4 L2,11.8 Q2,10.6 3.2,10.6 L20.8,10.6 Q22,10.6 22,11.8 L22,19.4 Q22,20.6 20.8,20.6 L3.2,20.6 Q2,20.6 2,19.4 Z">
                                    <Path.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#E8A845" Offset="0" />
                                            <GradientStop Color="#C07E28" Offset="1" />
                                        </LinearGradientBrush>
                                    </Path.Fill>
                                </Path>
                                <Path Fill="#F6C468" Data="M2,12.2 L2,11.8 Q2,10.6 3.2,10.6 L20.8,10.6 Q22,10.6 22,11.8 L22,12.2 Z" />
                            </Canvas>
                        </Viewbox>
                    </Button>
                </StackPanel>
            </Border>
        </Popup>
        <Border x:Name="HeaderBorder" DockPanel.Dock="Left" Width="64" Background="#FF141414">
            <StackPanel Orientation="Horizontal">
                <StackPanel Width="32" VerticalAlignment="Center">
                    <TextBlock x:Name="CountText" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" />
                    <Button x:Name="ToggleButton" Content="«" FontSize="14" Click="OnToggleCollapse" />
                    <Button Content="⌂" FontSize="12" Click="OnShowMain" ToolTip="Focus and center the TabDesktop window" />
                </StackPanel>
                <StackPanel x:Name="AdvancedButtons" Width="32" VerticalAlignment="Center">
                    <Button Content="⟳" FontSize="14" Click="OnRebuildRestart" ToolTip="Close, rebuild, and restart TabDesktop" />
                    <Button x:Name="ExtensionButton" Click="OnInstallExtension" ToolTip="Install the browser extension — video thumbnails straight from your tabs, including logged-in sites">
                        <Border x:Name="ExtensionIconChip" CornerRadius="3" Padding="2,0" Background="Transparent">
                            <Viewbox x:Name="ExtensionIcon" Width="13" Height="13" Opacity="0.4">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M4,9.5 Q4,8.5 5,8.5 L8.2,8.5 C6.9,6.7 7.8,4 10.2,4 C12.6,4 13.5,6.7 12.2,8.5 L15.4,8.5 Q16.4,8.5 16.4,9.5 L16.4,12.7 C18.2,11.4 20.9,12.3 20.9,14.7 C20.9,17.1 18.2,18 16.4,16.7 L16.4,19.9 Q16.4,20.9 15.4,20.9 L5,20.9 Q4,20.9 4,19.9 Z">
                                        <Path.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#8BC34A" Offset="0" />
                                                <GradientStop Color="#558B2F" Offset="1" />
                                            </LinearGradientBrush>
                                        </Path.Fill>
                                    </Path>
                                </Canvas>
                            </Viewbox>
                        </Border>
                    </Button>
                    <Button x:Name="HeightButton" Content="⇑" FontSize="12" Click="OnToggleDoubleHeight" ToolTip="Double the strip height — tiles stay the same size, so twice as many fit" />
                </StackPanel>
            </StackPanel>
        </Border>
        <StackPanel x:Name="ScrollButtons" DockPanel.Dock="Right" Orientation="Horizontal" Visibility="Collapsed">
            <Button Content="◀" Width="22" Click="OnScrollLeft" />
            <Button Content="▶" Width="22" Click="OnScrollRight" />
        </StackPanel>
        <Grid>
            <ScrollViewer x:Name="TabsScroll" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" PreviewMouseWheel="OnTabsWheel">
                <ItemsControl x:Name="Tabs">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <local:BottomAlignedColumnPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="TabRoot" Width="200" Padding="6,2" BorderBrush="#FF101010" BorderThickness="1" Cursor="Hand" ClipToBounds="True" MouseLeftButtonDown="OnTabMouseDown" MouseRightButtonUp="OnTabRightButtonUp" MouseMove="OnTabMouseMove" MouseLeftButtonUp="OnTabMouseUp" LostMouseCapture="OnTabLostCapture">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#FF2A2A2A" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsGroupLastFocused}" Value="True">
                                                <Setter Property="Background" Value="#FF4A4230" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsForeground}" Value="True">
                                                <Setter Property="Background" Value="#FF1E5E8A" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid Opacity="{Binding IdleOpacity}">
                                    <Border>
                                        <DockPanel>
                                            <Grid DockPanel.Dock="Left" Width="14" Height="13" Margin="0,1,4,0" VerticalAlignment="Top" ToolTip="Showing the process's directory — right-click the tab to toggle">
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding DirectoryTitle}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Path Data="M0,12 L0,2 Q0,1 1,1 L5,1 Q5.6,1 6,1.6 L7,3 L13,3 Q14,3 14,4 L14,12 Q14,13 13,13 L1,13 Q0,13 0,12 Z" Fill="#D99C2B" />
                                                <Path Data="M0,12 L0,5.5 Q0,4.5 1,4.5 L13,4.5 Q14,4.5 14,5.5 L14,12 Q14,13 13,13 L1,13 Q0,13 0,12 Z" Fill="#FFD35C" />
                                            </Grid>
                                            <Image DockPanel.Dock="Left" Source="{Binding VideoThumbnail}" Height="48" Stretch="Uniform" Margin="0,0,4,0" VerticalAlignment="Top" RenderOptions.BitmapScalingMode="HighQuality">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding VideoThumbnail}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <Image DockPanel.Dock="Left" Source="{Binding IconImage}" Width="16" Height="16" Margin="0,0,4,0" VerticalAlignment="Top">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                            <TextBlock Text="{Binding DisplayTitle}" Foreground="White" FontSize="12" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxHeight="48" />
                                        </DockPanel>
                                    </Border>
                                    <Border x:Name="HoverOverlay" Background="#30000000" Margin="-6,-2" Visibility="Collapsed" />
                                    <Rectangle Width="3" Margin="-6,-2" HorizontalAlignment="Left" Fill="#CCFFFFFF" IsHitTestVisible="False" ToolTip="A browser tab of an expanded window, not a window of its own">
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BrowserTab}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="TabRoot" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverOverlay" Property="Visibility" Value="Visible" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                    <Setter TargetName="TabRoot" Property="Opacity" Value="0.45" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            <Canvas x:Name="IndicatorCanvas" IsHitTestVisible="False">
                <Rectangle x:Name="DropIndicator" Height="2" Fill="#FF4A9EDE" Visibility="Collapsed" />
            </Canvas>
        </Grid>
    </DockPanel>
</Window>
